# Supabase (required) — fill from `pnpm supabase:start` output or your Supabase Cloud project
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only Postgres URL for Drizzle migrations / seeds (port 54322 = supabase local)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# App Config (optional overrides)
PUBLIC_APP_MODE=both
PUBLIC_APP_NAME=VaultFlow
PUBLIC_DEFAULT_CURRENCY=USD
PUBLIC_DEFAULT_TIMEZONE=UTC

# Feature Flags
PUBLIC_FEATURE_REALTIME=true
PUBLIC_FEATURE_FRAUD=true
PUBLIC_FEATURE_EXPORTS=true
PUBLIC_FEATURE_REPORTS=true
