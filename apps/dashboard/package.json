{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test --project=accessibility",
    "test:mobile": "playwright test --project=mobile",
    "test": "pnpm test:unit && pnpm test:e2e",
    "db:reset": "supabase db reset --local",
    "db:studio": "supabase studio",
    "db:types": "supabase gen types typescript --local > src/lib/types/database.types.ts",
    "seed:dev": "tsx --env-file=.env.local src/lib/db/seed/index.ts",
    "seed:reset": "tsx --env-file=.env.local src/lib/db/seed/index.ts --reset",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop"
  },
  "dependencies": {
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/ubuntu-mono": "^5.2.8",
    "@lucide/svelte": "^1.16.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "layerchart": "^1.0.13",
    "postgres": "^3.4.9",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.1",
    "@vaultflow/config": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "supabase": "^2.101.0",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
