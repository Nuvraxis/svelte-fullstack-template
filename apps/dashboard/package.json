{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test --project=accessibility",
    "test:mobile": "playwright test --project=mobile",
    "test": "pnpm test:unit && pnpm test:e2e",
    "db:reset": "supabase db reset --local",
    "db:studio": "supabase studio",
    "db:types": "supabase gen types typescript --local > src/lib/types/database.types.ts",
    "seed:dev": "tsx --env-file=.env.local src/lib/db/seed/index.ts",
    "seed:reset": "tsx --env-file=.env.local src/lib/db/seed/index.ts --reset",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop"
  },
  "dependencies": {
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/ubuntu-mono": "^5.2.8",
    "@lucide/svelte": "^1.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "bits-ui": "^1.0.0-next.65",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "layerchart": "^1.0.0",
    "postgres": "^3.4.5",
    "tailwind-merge": "^2.5.4",
    "tailwind-variants": "^0.3.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@faker-js/faker": "^9.2.0",
    "@playwright/test": "^1.49.0",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.8.3",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0-beta.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.6",
    "@types/node": "^22.10.1",
    "@vaultflow/config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.16.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.13.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.6",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "supabase": "^2.1.4",
    "svelte": "^5.2.7",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.0.0-beta.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vite": "^6.0.1",
    "vitest": "^3.0.0"
  }
}
